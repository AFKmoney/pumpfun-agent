# =========================================================================
# .env.example - SECRETS
# Copy to .env and fill in. NEVER commit .env to git.
# =========================================================================

# ---- Solana Wallet Connection ----
# Choose ONE method (the bot uses the first it finds, in this order):
#
#   Method 1 — PRIVATE KEY (recommended for Phantom/pump.fun users):
#     In Phantom: Settings → Account → Show Private Key → copy the base58 string
SOLANA_PRIVATE_KEY=""
#
#   Method 2 — KEYPAIR JSON (Solana CLI format):
#     An array of 64 numbers, e.g. [123,45,67,...,89]
SOLANA_KEYPAIR_JSON=""
#
#   Method 3 — SEED PHRASE (12 or 24 words):
SOLANA_WALLET_SEED=""
#
# Run `python scripts/check_wallet.py` after setting one of these to verify.

# ---- EVM (Base / Ethereum) ----
BASE_WALLET_PRIVKEY="0xabc..."
ETH_WALLET_PRIVKEY="0xabc..."

# ---- Telegram ----
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="987654321"

# ---- RPC providers ----
HELIUS_API_KEY="hel-..."
ALCHEMY_API_KEY="..."

# ---- Birdeye (OHLCV for backtesting, optional) ----
BIRDEYE_API_KEY=""
DEXSCREENER_API_KEY=""

# ---- Sentiment analytics (optional but feeds the AlphaSignal brain) ----
# Twitter API v2 bearer token — needed for sentiment.fetch_twitter_mentions.
# Without it, the sentiment analyzer always returns 0 hype.
TWITTER_BEARER_TOKEN=""

# ---- Dashboard (optional) ----
DASHBOARD_TOKEN=""   # if set, /api/kill requires ?token=...
