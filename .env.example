# =========================================================================
# .env.example - SECRETS
# Copy to .env and fill in. NEVER commit .env to git.
# =========================================================================

# ---- Solana ----
SOLANA_WALLET_SEED="word1 word2 word3 ... word12"   # 12 or 24 word seed phrase

# ---- EVM (Base / Ethereum) ----
BASE_WALLET_PRIVKEY="0xabc..."
ETH_WALLET_PRIVKEY="0xabc..."

# ---- Telegram ----
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="987654321"

# ---- RPC providers ----
HELIUS_API_KEY="hel-..."
ALCHEMY_API_KEY="..."

# ---- Birdeye (OHLCV for backtesting, optional) ----
BIRDEYE_API_KEY=""
DEXSCREENER_API_KEY=""

# ---- Dashboard (optional) ----
DASHBOARD_TOKEN=""   # if set, /api/kill requires ?token=...
